<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payable_installment_tree" model="ir.ui.view">
        <field name="name">payable.installment.tree</field>
        <field name="model">payable.installment</field>
        <field name="arch" type="xml">
            <list>
                <field name="title_id"/>
                <field name="sequence"/>
                <field name="due_date"/>
                <field name="amount"/>
                <field name="amount_open"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_payable_installment_form" model="ir.ui.view">
        <field name="name">payable.installment.form</field>
        <field name="model">payable.installment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="title_id"/>
                        <field name="sequence"/>
                        <field name="due_date"/>
                        <field name="amount"/>
                        <field name="amount_open" readonly="1"/>
                        <field name="state"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_payable_installment" model="ir.actions.act_window">
        <field name="name">Parcelas</field>
        <field name="res_model">payable.installment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_payable_installment"
        name="Parcelas"
        parent="custom_account_payable.custom_account_payable_menu_root"
        action="action_payable_installment"
        sequence="20"
    />
</odoo>

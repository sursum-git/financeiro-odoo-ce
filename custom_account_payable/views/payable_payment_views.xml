<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payable_payment_tree" model="ir.ui.view">
        <field name="name">payable.payment.tree</field>
        <field name="model">payable.payment</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="gross_amount_total"/>
                <field name="withholding_amount_total"/>
                <field name="net_amount_total"/>
                <field name="payment_method_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_payable_payment_form" model="ir.ui.view">
        <field name="name">payable.payment.form</field>
        <field name="model">payable.payment</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                    </group>
                    <group>
                        <field name="payment_method_id"/>
                        <field name="source_account_id"/>
                        <field name="source_portador_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="gross_amount_total" readonly="1"/>
                        <field name="withholding_amount_total" readonly="1"/>
                        <field name="net_amount_total" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="line_ids"/>
                    </group>
                    <group>
                        <field name="withholding_line_ids" readonly="1">
                            <list>
                                <field name="withholding_code_id"/>
                                <field name="supplier_contact_id"/>
                                <field name="retention_percent"/>
                                <field name="base_amount"/>
                                <field name="previously_withheld_amount"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_payable_payment" model="ir.actions.act_window">
        <field name="name">Pagamentos</field>
        <field name="res_model">payable.payment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_payable_payment"
        name="Pagamentos"
        parent="custom_account_payable.custom_account_payable_menu_root"
        action="action_payable_payment"
        sequence="30"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_payable_schedule_tree" model="ir.ui.view">
        <field name="name">payable.schedule.tree</field>
        <field name="model">payable.schedule</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="payment_date"/>
                <field name="partner_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_payable_schedule_form" model="ir.ui.view">
        <field name="name">payable.schedule.form</field>
        <field name="model">payable.schedule</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="payment_date"/>
                        <field name="company_id"/>
                        <field name="partner_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_payable_schedule" model="ir.actions.act_window">
        <field name="name">Programacoes</field>
        <field name="res_model">payable.schedule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_payable_schedule"
        name="Programacoes"
        parent="custom_account_payable.custom_account_payable_menu_root"
        action="action_payable_schedule"
        sequence="40"
    />
</odoo>

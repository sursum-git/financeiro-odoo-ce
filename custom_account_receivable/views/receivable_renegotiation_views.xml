<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_renegotiation_tree" model="ir.ui.view">
        <field name="name">receivable.renegotiation.tree</field>
        <field name="model">receivable.renegotiation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="new_title_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_receivable_renegotiation_form" model="ir.ui.view">
        <field name="name">receivable.renegotiation.form</field>
        <field name="model">receivable.renegotiation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="partner_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="source_title_ids"/>
                        <field name="new_title_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivable_renegotiation" model="ir.actions.act_window">
        <field name="name">Renegociacoes</field>
        <field name="res_model">receivable.renegotiation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_receivable_renegotiation"
        name="Renegociacoes"
        parent="custom_account_receivable.custom_account_receivable_menu_root"
        action="action_receivable_renegotiation"
        sequence="40"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_renegotiation_wizard_form" model="ir.ui.view">
        <field name="name">receivable.renegotiation.wizard.form</field>
        <field name="model">receivable.renegotiation.wizard</field>
        <field name="arch" type="xml">
            <form string="Renegotiate Title">
                <sheet>
                    <group>
                        <field name="source_title_id"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                        <field name="source_amount_open"/>
                    </group>
                    <group>
                        <field name="new_title_name"/>
                        <field name="issue_date"/>
                        <field name="origin_reference"/>
                        <field name="new_amount_total" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="installment_line_ids">
                            <list editable="bottom">
                                <field name="sequence"/>
                                <field name="due_date"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirm" type="object" class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

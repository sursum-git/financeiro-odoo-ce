<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_settlement_tree" model="ir.ui.view">
        <field name="name">receivable.settlement.tree</field>
        <field name="model">receivable.settlement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="settlement_kind"/>
                <field name="currency_id"/>
                <field name="gross_amount_total"/>
                <field name="gross_amount_company_currency" optional="hide"/>
                <field name="withholding_amount_total"/>
                <field name="net_amount_total"/>
                <field name="net_amount_company_currency" optional="hide"/>
                <field name="payment_method_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_receivable_settlement_form" model="ir.ui.view">
        <field name="name">receivable.settlement.form</field>
        <field name="model">receivable.settlement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                    </group>
                    <group>
                        <field name="settlement_kind"/>
                        <field name="payment_method_id"/>
                        <field name="portador_id"/>
                        <field name="target_account_id"/>
                        <field name="currency_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="exchange_rate" readonly="1"/>
                        <field name="company_currency_id" readonly="1"/>
                        <field name="gross_amount_total" readonly="1"/>
                        <field name="gross_amount_company_currency" readonly="1"/>
                        <field name="withholding_amount_total" readonly="1"/>
                        <field name="withholding_amount_company_currency" readonly="1"/>
                        <field name="net_amount_total" readonly="1"/>
                        <field name="net_amount_company_currency" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="line_ids"/>
                    </group>
                    <group invisible="settlement_kind != 'third_party_check'">
                        <field name="third_party_check_line_ids">
                            <list editable="bottom">
                                <field name="issuer_name"/>
                                <field name="check_number"/>
                                <field name="bank_name"/>
                                <field name="branch"/>
                                <field name="account_number"/>
                                <field name="expected_clearance_date"/>
                                <field name="amount"/>
                                <field name="notes"/>
                            </list>
                        </field>
                    </group>
                    <group>
                        <field name="withholding_line_ids" readonly="1" invisible="settlement_kind == 'third_party_check'">
                            <list>
                                <field name="withholding_code_id"/>
                                <field name="supplier_contact_id"/>
                                <field name="retention_percent"/>
                                <field name="base_amount"/>
                                <field name="previously_withheld_amount"/>
                                <field name="amount"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivable_settlement" model="ir.actions.act_window">
        <field name="name">Liquidacoes</field>
        <field name="res_model">receivable.settlement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_receivable_settlement"
        name="Liquidacoes"
        parent="custom_account_receivable.custom_account_receivable_menu_root"
        action="action_receivable_settlement"
        sequence="30"
    />
</odoo>

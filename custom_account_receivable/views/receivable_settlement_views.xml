<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_settlement_tree" model="ir.ui.view">
        <field name="name">receivable.settlement.tree</field>
        <field name="model">receivable.settlement</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="partner_id"/>
                <field name="payment_method_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_receivable_settlement_form" model="ir.ui.view">
        <field name="name">receivable.settlement.form</field>
        <field name="model">receivable.settlement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                    </group>
                    <group>
                        <field name="payment_method_id"/>
                        <field name="portador_id"/>
                        <field name="target_account_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="line_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivable_settlement" model="ir.actions.act_window">
        <field name="name">Liquidacoes</field>
        <field name="res_model">receivable.settlement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_receivable_settlement"
        name="Liquidacoes"
        parent="custom_account_receivable.custom_account_receivable_menu_root"
        action="action_receivable_settlement"
        sequence="30"
    />
</odoo>

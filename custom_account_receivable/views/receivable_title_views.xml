<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_title_tree" model="ir.ui.view">
        <field name="name">receivable.title.tree</field>
        <field name="model">receivable.title</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="species_id"/>
                <field name="issue_date"/>
                <field name="amount_total"/>
                <field name="amount_open"/>
                <field name="check_number" optional="hide"/>
                <field name="expected_clearance_date" optional="hide"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_receivable_title_form" model="ir.ui.view">
        <field name="name">receivable.title.form</field>
        <field name="model">receivable.title</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_open_renegotiation_wizard"
                        string="Renegociar"
                        type="object"
                        class="btn-primary"
                        invisible="state not in ('open', 'partial')"
                    />
                    <button
                        name="action_open_check_compensation_wizard"
                        string="Compensar Cheque"
                        type="object"
                        class="btn-primary"
                        invisible="species_kind != 'check' or state not in ('open', 'partial')"
                    />
                    <button
                        name="action_open_check_return_wizard"
                        string="Devolver Cheque"
                        type="object"
                        invisible="species_kind != 'check' or state not in ('open', 'partial')"
                    />
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="company_id"/>
                        <field name="issue_date"/>
                        <field name="origin_reference"/>
                    </group>
                    <group>
                        <field name="species_id"/>
                        <field name="amount_total"/>
                        <field name="amount_open" readonly="1"/>
                        <field name="currency_id"/>
                        <field name="state"/>
                    </group>
                    <group invisible="species_kind != 'check'">
                        <field name="source_title_id" readonly="1"/>
                        <field name="source_settlement_id" readonly="1"/>
                        <field name="check_status" readonly="1"/>
                        <field name="replacement_title_id" readonly="1"/>
                    </group>
                    <group invisible="species_kind != 'check'">
                        <field name="check_issuer_name" readonly="1"/>
                        <field name="check_number" readonly="1"/>
                        <field name="check_bank_name" readonly="1"/>
                        <field name="check_branch" readonly="1"/>
                        <field name="check_account_number" readonly="1"/>
                    </group>
                    <group invisible="species_kind != 'check'">
                        <field name="expected_clearance_date" readonly="1"/>
                        <field name="actual_clearance_date" readonly="1"/>
                        <field name="last_return_date" readonly="1"/>
                        <field name="return_count" readonly="1"/>
                        <field name="check_return_reason_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="installment_ids"/>
                    </group>
                    <group invisible="species_kind != 'check'">
                        <field name="generated_check_title_ids" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivable_third_party_checks" model="ir.actions.act_window">
        <field name="name">Cheques de Terceiros</field>
        <field name="res_model">receivable.title</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[("species_kind", "=", "check")]</field>
    </record>

    <record id="action_receivable_title" model="ir.actions.act_window">
        <field name="name">Titulos</field>
        <field name="res_model">receivable.title</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_receivable_title"
        name="Titulos"
        parent="custom_account_receivable.custom_account_receivable_menu_root"
        action="action_receivable_title"
        sequence="10"
    />

    <menuitem
        id="menu_receivable_third_party_checks"
        name="Cheques de Terceiros"
        parent="custom_account_receivable.custom_account_receivable_menu_root"
        action="action_receivable_third_party_checks"
        sequence="20"
    />
</odoo>

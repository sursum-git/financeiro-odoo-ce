<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_receivable_collection_user" model="res.groups">
        <field name="name">Cobranca de Receber - Usuario</field>
        <field name="implied_ids" eval="[(4, ref('custom_account_receivable.group_receivable_user')), (4, ref('custom_treasury_cash.group_treasury_cash_user'))]"/>
    </record>

    <record id="group_receivable_collection_manager" model="res.groups">
        <field name="name">Cobranca de Receber - Gerente</field>
        <field name="implied_ids" eval="[(4, ref('custom_account_receivable_collection.group_receivable_collection_user'))]"/>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_collection_agent_tree" model="ir.ui.view">
        <field name="name">receivable.collection.agent.tree</field>
        <field name="model">receivable.collection.agent</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="user_id"/>
                <field name="portador_id"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_receivable_collection_agent_form" model="ir.ui.view">
        <field name="name">receivable.collection.agent.form</field>
        <field name="model">receivable.collection.agent</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                        <field name="user_id"/>
                    </group>
                    <group>
                        <field name="portador_id"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="assignment_ids" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivable_collection_agent" model="ir.actions.act_window">
        <field name="name">Cobradores</field>
        <field name="res_model">receivable.collection.agent</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_receivable_collection_agent"
        name="Cobradores"
        parent="custom_account_receivable_collection.custom_account_receivable_collection_menu_root"
        action="action_receivable_collection_agent"
        sequence="10"
    />
</odoo>

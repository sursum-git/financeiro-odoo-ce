<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_receivable_collection_route_tree" model="ir.ui.view">
        <field name="name">receivable.collection.route.tree</field>
        <field name="model">receivable.collection.route</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="company_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_receivable_collection_route_form" model="ir.ui.view">
        <field name="name">receivable.collection.route.form</field>
        <field name="model">receivable.collection.route</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="company_id"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="assignment_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_receivable_collection_route" model="ir.actions.act_window">
        <field name="name">Roteiros</field>
        <field name="res_model">receivable.collection.route</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_receivable_collection_route"
        name="Roteiros"
        parent="custom_account_receivable_collection.custom_account_receivable_collection_menu_root"
        action="action_receivable_collection_route"
        sequence="20"
    />
</odoo>

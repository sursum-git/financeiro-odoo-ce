<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_check_return_reason_tree" model="ir.ui.view">
        <field name="name">financial.check.return.reason.tree</field>
        <field name="model">financial.check.return.reason</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="is_definitive"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_financial_check_return_reason_form" model="ir.ui.view">
        <field name="name">financial.check.return.reason.form</field>
        <field name="model">financial.check.return.reason</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="is_definitive"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_check_return_reason" model="ir.actions.act_window">
        <field name="name">Motivos de Devolucao de Cheque</field>
        <field name="res_model">financial.check.return.reason</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_financial_check_return_reason"
        name="Motivos de Devolucao de Cheque"
        parent="custom_financial_base.custom_financial_base_menu_config"
        action="action_financial_check_return_reason"
        sequence="16"
    />
</odoo>

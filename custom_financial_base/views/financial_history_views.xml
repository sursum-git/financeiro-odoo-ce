<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_history_tree" model="ir.ui.view">
        <field name="name">financial.history.tree</field>
        <field name="model">financial.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_financial_history_form" model="ir.ui.view">
        <field name="name">financial.history.form</field>
        <field name="model">financial.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_history" model="ir.actions.act_window">
        <field name="name">Historicos</field>
        <field name="res_model">financial.history</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_financial_history"
        name="Historicos"
        parent="custom_financial_base.custom_financial_base_menu_config"
        action="action_financial_history"
        sequence="40"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_portador_tree" model="ir.ui.view">
        <field name="name">financial.portador.tree</field>
        <field name="model">financial.portador</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="type"/>
                <field name="currency_id"/>
                <field name="controla_saldo"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_financial_portador_form" model="ir.ui.view">
        <field name="name">financial.portador.form</field>
        <field name="model">financial.portador</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="type"/>
                        <field name="currency_id"/>
                        <field name="company_id"/>
                        <field name="controla_saldo"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_portador" model="ir.actions.act_window">
        <field name="name">Portadores</field>
        <field name="res_model">financial.portador</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_financial_portador"
        name="Portadores"
        parent="custom_financial_base.custom_financial_base_menu_config"
        action="action_financial_portador"
        sequence="10"
    />
</odoo>

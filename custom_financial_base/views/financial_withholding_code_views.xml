<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_withholding_code_tree" model="ir.ui.view">
        <field name="name">financial.withholding.code.tree</field>
        <field name="model">financial.withholding.code</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="due_date"/>
                <field name="minimum_retention_amount"/>
                <field name="minimum_payment_amount"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_financial_withholding_code_form" model="ir.ui.view">
        <field name="name">financial.withholding.code.form</field>
        <field name="model">financial.withholding.code</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="due_date"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="minimum_retention_amount"/>
                        <field name="minimum_payment_amount"/>
                    </group>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_withholding_code" model="ir.actions.act_window">
        <field name="name">Codigos de Retencao</field>
        <field name="res_model">financial.withholding.code</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_financial_withholding_code"
        name="Codigos de Retencao"
        parent="custom_financial_base.custom_financial_base_menu_config"
        action="action_financial_withholding_code"
        sequence="15"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_integration_event_tree" model="ir.ui.view">
        <field name="name">financial.integration.event.tree</field>
        <field name="model">financial.integration.event</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="event_type"/>
                <field name="source_model"/>
                <field name="source_record_id"/>
                <field name="treasury_movement_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_financial_integration_event_form" model="ir.ui.view">
        <field name="name">financial.integration.event.form</field>
        <field name="model">financial.integration.event</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="event_type"/>
                        <field name="state"/>
                    </group>
                    <group>
                        <field name="source_module"/>
                        <field name="source_model"/>
                        <field name="source_record_id"/>
                        <field name="treasury_movement_id"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="log_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_integration_event" model="ir.actions.act_window">
        <field name="name">Eventos</field>
        <field name="res_model">financial.integration.event</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_financial_integration_event"
        name="Eventos"
        parent="custom_financial_integration.custom_financial_integration_menu_root"
        action="action_financial_integration_event"
        sequence="10"
    />
</odoo>

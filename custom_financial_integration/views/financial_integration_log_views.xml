<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_integration_log_tree" model="ir.ui.view">
        <field name="name">financial.integration.log.tree</field>
        <field name="model">financial.integration.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="event_id"/>
                <field name="level"/>
                <field name="created_at"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="view_financial_integration_log_form" model="ir.ui.view">
        <field name="name">financial.integration.log.form</field>
        <field name="model">financial.integration.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="event_id"/>
                        <field name="level"/>
                        <field name="created_at"/>
                    </group>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_integration_log" model="ir.actions.act_window">
        <field name="name">Registros</field>
        <field name="res_model">financial.integration.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_financial_integration_log"
        name="Registros"
        parent="custom_financial_integration.custom_financial_integration_menu_root"
        action="action_financial_integration_log"
        sequence="20"
    />
</odoo>

        <field name="name">Relatorios Financeiros - Usuario</field>
        <field name="implied_ids" eval="[(4, ref('custom_treasury.group_treasury_user')), (4, ref('custom_account_receivable.group_receivable_user')), (4, ref('custom_account_payable.group_payable_user'))]"/>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_report_helper_payable_form" model="ir.ui.view">
        <field name="name">financial.report.helper.payable.form</field>
        <field name="model">financial.report.helper</field>
        <field name="arch" type="xml">
            <form create="true" edit="true" delete="true">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="partner_id"/>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="currency_id"/>
                    </group>
                    <group string="Contas a Pagar">
                        <button name="action_open_payable_open_position" type="object" string="Posicao em Aberto" class="btn-primary"/>
                        <button name="action_open_payment_schedule" type="object" string="Agenda de Pagamentos"/>
                        <button name="action_open_payment_history" type="object" string="Historico de Pagamentos"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_reports_payable" model="ir.actions.act_window">
        <field name="name">Relatorios de Pagar</field>
        <field name="res_model">financial.report.helper</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_financial_report_helper_payable_form"/>
        <field name="target">current</field>
    </record>

    <menuitem
        id="menu_financial_reports_payable"
        name="Relatorios"
        parent="custom_account_payable.custom_account_payable_menu_root"
        action="action_financial_reports_payable"
        sequence="50"
    />
</odoo>

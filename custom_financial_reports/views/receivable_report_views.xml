<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_financial_report_helper_receivable_form" model="ir.ui.view">
        <field name="name">financial.report.helper.receivable.form</field>
        <field name="model">financial.report.helper</field>
        <field name="arch" type="xml">
            <form create="true" edit="true" delete="true">
                <sheet>
                    <group>
                        <field name="company_id"/>
                        <field name="partner_id"/>
                        <field name="reference_date"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="date_from"/>
                        <field name="date_to"/>
                        <field name="agent_id"/>
                        <field name="route_id"/>
                    </group>
                    <group string="Contas a Receber">
                        <button name="action_open_receivable_open_position" type="object" string="Posicao em Aberto" class="btn-primary"/>
                        <button name="action_open_receivable_aging" type="object" string="Vencidos por Faixa"/>
                        <button name="action_open_receivable_settlement_history" type="object" string="Historico de Liquidacoes"/>
                    </group>
                    <group string="Cobranca">
                        <button name="action_open_collection_accountability" type="object" string="Prestacao por Cobrador"/>
                        <button name="action_open_titles_in_route" type="object" string="Titulos em Rota"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_financial_reports_receivable" model="ir.actions.act_window">
        <field name="name">Relatorios de Receber</field>
        <field name="res_model">financial.report.helper</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_financial_report_helper_receivable_form"/>
        <field name="target">current</field>
    </record>

    <menuitem
        id="menu_financial_reports_receivable"
        name="Relatorios"
        parent="custom_account_receivable.custom_account_receivable_menu_root"
        action="action_financial_reports_receivable"
        sequence="70"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_account_tree" model="ir.ui.view">
        <field name="name">treasury.account.tree</field>
        <field name="model">treasury.account</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="type"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_account_form" model="ir.ui.view">
        <field name="name">treasury.account.form</field>
        <field name="model">treasury.account</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="type"/>
                        <field name="company_id"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="modality_link_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_account" model="ir.actions.act_window">
        <field name="name">Contas Financeiras</field>
        <field name="res_model">treasury.account</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_account"
        name="Contas Financeiras"
        parent="custom_treasury.custom_treasury_menu_config"
        action="action_treasury_account"
        sequence="10"
    />
</odoo>

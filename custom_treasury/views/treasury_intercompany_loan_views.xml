<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_intercompany_loan_tree" model="ir.ui.view">
        <field name="name">treasury.intercompany.loan.tree</field>
        <field name="model">treasury.intercompany.loan</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="name"/>
                <field name="lender_company_id"/>
                <field name="borrower_company_id"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_intercompany_loan_form" model="ir.ui.view">
        <field name="name">treasury.intercompany.loan.form</field>
        <field name="model">treasury.intercompany.loan</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button
                        name="action_confirm"
                        type="object"
                        string="Confirmar"
                        invisible="state != 'draft'"
                    />
                    <button
                        name="action_cancel"
                        type="object"
                        string="Cancelar"
                        invisible="state != 'confirmed'"
                    />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancelled"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="currency_id"/>
                        <field name="amount"/>
                    </group>
                    <group string="Empresas">
                        <field name="lender_company_id"/>
                        <field name="borrower_company_id"/>
                    </group>
                    <group string="Origem">
                        <field name="source_account_id"/>
                        <field name="source_portador_id"/>
                    </group>
                    <group string="Destino">
                        <field name="target_account_id"/>
                        <field name="target_portador_id"/>
                    </group>
                    <group string="Rastreabilidade">
                        <field name="out_movement_id" readonly="1"/>
                        <field name="in_movement_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_intercompany_loan" model="ir.actions.act_window">
        <field name="name">Mutuos Entre Empresas</field>
        <field name="res_model">treasury.intercompany.loan</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_intercompany_loan"
        name="Mutuos Entre Empresas"
        parent="custom_treasury.custom_treasury_menu_operations"
        action="action_treasury_intercompany_loan"
        sequence="15"
    />
</odoo>

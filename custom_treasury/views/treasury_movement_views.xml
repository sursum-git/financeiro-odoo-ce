<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_movement_tree" model="ir.ui.view">
        <field name="name">treasury.movement.tree</field>
        <field name="model">treasury.movement</field>
        <field name="arch" type="xml">
            <list>
                <field name="date"/>
                <field name="name"/>
                <field name="type"/>
                <field name="amount"/>
                <field name="currency_id"/>
                <field name="amount_company_currency"/>
                <field name="company_currency_id"/>
                <field name="account_id"/>
                <field name="portador_id"/>
                <field name="state"/>
                <field name="is_reconciled"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_movement_form" model="ir.ui.view">
        <field name="name">treasury.movement.form</field>
        <field name="model">treasury.movement</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="company_id"/>
                        <field name="type"/>
                        <field name="amount"/>
                        <field name="currency_id"/>
                        <field name="exchange_rate" readonly="1"/>
                        <field name="amount_company_currency" readonly="1"/>
                        <field name="company_currency_id" readonly="1"/>
                        <field name="state"/>
                        <field name="is_reconciled"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="account_id"/>
                        <field name="portador_id"/>
                        <field name="payment_method_id"/>
                        <field name="history_id"/>
                        <field name="reason_id"/>
                    </group>
                    <group string="Origem">
                        <field name="origin_module"/>
                        <field name="origin_model"/>
                        <field name="origin_record_id"/>
                        <field name="reversed_movement_id"/>
                    </group>
                    <notebook>
                        <page string="Linhas de Pagamento">
                            <field name="payment_line_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_movement" model="ir.actions.act_window">
        <field name="name">Movimentos</field>
        <field name="res_model">treasury.movement</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_movement"
        name="Movimentos"
        parent="custom_treasury.custom_treasury_menu_operations"
        action="action_treasury_movement"
        sequence="10"
    />
</odoo>

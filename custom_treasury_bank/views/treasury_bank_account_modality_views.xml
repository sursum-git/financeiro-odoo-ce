<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_bank_account_modality_tree" model="ir.ui.view">
        <field name="name">treasury.bank.account.modality.tree</field>
        <field name="model">treasury.bank.account.modality</field>
        <field name="arch" type="xml">
            <list>
                <field name="bank_account_id"/>
                <field name="modality_id"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_bank_account_modality_form" model="ir.ui.view">
        <field name="name">treasury.bank.account.modality.form</field>
        <field name="model">treasury.bank.account.modality</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="bank_account_id"/>
                        <field name="modality_id"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_bank_account_modality" model="ir.actions.act_window">
        <field name="name">Conta Bancaria x Modalidade</field>
        <field name="res_model">treasury.bank.account.modality</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_bank_account_modality"
        name="Conta x Modalidade"
        parent="custom_treasury_bank.custom_treasury_bank_menu_root"
        action="action_treasury_bank_account_modality"
        sequence="30"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_bank_tree" model="ir.ui.view">
        <field name="name">treasury.bank.tree</field>
        <field name="model">treasury.bank</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_bank_form" model="ir.ui.view">
        <field name="name">treasury.bank.form</field>
        <field name="model">treasury.bank</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="active"/>
                    </group>
                    <group>
                        <field name="account_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_bank" model="ir.actions.act_window">
        <field name="name">Bancos</field>
        <field name="res_model">treasury.bank</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_bank"
        name="Bancos"
        parent="custom_treasury_bank.custom_treasury_bank_menu_root"
        action="action_treasury_bank"
        sequence="10"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_cash_accountability_tree" model="ir.ui.view">
        <field name="name">treasury.cash.accountability.tree</field>
        <field name="model">treasury.cash.accountability</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="source_portador_id"/>
                <field name="target_account_id"/>
                <field name="target_portador_id"/>
                <field name="amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_cash_accountability_form" model="ir.ui.view">
        <field name="name">treasury.cash.accountability.form</field>
        <field name="model">treasury.cash.accountability</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" invisible="state != 'draft'"/>
                    <button name="action_cancel" string="Cancelar" type="object" invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="date"/>
                        <field name="company_id"/>
                        <field name="amount"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="source_portador_id"/>
                        <field name="target_account_id"/>
                        <field name="target_portador_id"/>
                    </group>
                    <group>
                        <field name="out_movement_id"/>
                        <field name="in_movement_id"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_cash_accountability" model="ir.actions.act_window">
        <field name="name">Prestacoes de Contas</field>
        <field name="res_model">treasury.cash.accountability</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_cash_accountability"
        name="Prestacoes de Contas"
        parent="custom_treasury_cash.custom_treasury_cash_menu_root"
        action="action_treasury_cash_accountability"
        sequence="30"
    />
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_cash_box_tree" model="ir.ui.view">
        <field name="name">treasury.cash.box.tree</field>
        <field name="model">treasury.cash.box</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="portador_id"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_cash_box_form" model="ir.ui.view">
        <field name="name">treasury.cash.box.form</field>
        <field name="model">treasury.cash.box</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="company_id"/>
                        <field name="portador_id"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_cash_box" model="ir.actions.act_window">
        <field name="name">Caixas</field>
        <field name="res_model">treasury.cash.box</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_cash_box"
        name="Caixas"
        parent="custom_treasury_cash.custom_treasury_cash_menu_root"
        action="action_treasury_cash_box"
        sequence="10"
    />
</odoo>

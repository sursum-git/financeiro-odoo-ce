<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_cash_operation_wizard_form" model="ir.ui.view">
        <field name="name">treasury.cash.operation.wizard.form</field>
        <field name="model">treasury.cash.operation.wizard</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="session_id"/>
                        <field name="company_id"/>
                        <field name="operation_type"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="amount"/>
                        <field name="history_id"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm" string="Confirmar" type="object" class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

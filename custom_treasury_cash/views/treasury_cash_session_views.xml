<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_cash_session_tree" model="ir.ui.view">
        <field name="name">treasury.cash.session.tree</field>
        <field name="model">treasury.cash.session</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="cash_box_id"/>
                <field name="user_id"/>
                <field name="currency_id"/>
                <field name="opening_amount"/>
                <field name="closing_amount_computed"/>
                <field name="difference_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_cash_session_form" model="ir.ui.view">
        <field name="name">treasury.cash.session.form</field>
        <field name="model">treasury.cash.session</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_open" string="Abrir" type="object" invisible="state != 'draft'"/>
                    <button name="action_open_supply_wizard" string="Suprimento" type="object" invisible="state != 'open'"/>
                    <button name="action_open_withdrawal_wizard" string="Sangria" type="object" invisible="state != 'open'"/>
                    <button name="action_close" string="Fechar" type="object" invisible="state != 'open'"/>
                    <button name="action_cancel" string="Cancelar" type="object" invisible="state not in ('draft','open')"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="cash_box_id"/>
                        <field name="company_id"/>
                        <field name="user_id"/>
                        <field name="currency_id"/>
                    </group>
                    <group>
                        <field name="opened_at"/>
                        <field name="opening_amount"/>
                        <field name="closed_at"/>
                        <field name="closing_amount_informed"/>
                        <field name="closing_amount_computed" readonly="1"/>
                        <field name="difference_amount" readonly="1"/>
                        <field name="difference_reason"/>
                    </group>
                    <group>
                        <field name="line_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_cash_session" model="ir.actions.act_window">
        <field name="name">Sessoes de Caixa</field>
        <field name="res_model">treasury.cash.session</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_cash_session"
        name="Sessoes"
        parent="custom_treasury_cash.custom_treasury_cash_menu_root"
        action="action_treasury_cash_session"
        sequence="20"
    />
</odoo>

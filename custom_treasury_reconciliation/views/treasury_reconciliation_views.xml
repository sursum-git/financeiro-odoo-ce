<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_treasury_reconciliation_tree" model="ir.ui.view">
        <field name="name">treasury.reconciliation.tree</field>
        <field name="model">treasury.reconciliation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="bank_account_id"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_reconciliation_form" model="ir.ui.view">
        <field name="name">treasury.reconciliation.form</field>
        <field name="model">treasury.reconciliation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_suggest_matches" string="Carregar e Sugerir" type="object" invisible="state == 'done'"/>
                    <button name="action_finalize" string="Finalizar" type="object" invisible="state != 'in_progress'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="company_id"/>
                        <field name="bank_account_id"/>
                    </group>
                    <group>
                        <field name="date_start"/>
                        <field name="date_end"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                    <group>
                        <field name="line_ids"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_treasury_reconciliation_line_tree" model="ir.ui.view">
        <field name="name">treasury.reconciliation.line.tree</field>
        <field name="model">treasury.reconciliation.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="statement_line_id"/>
                <field name="movement_id"/>
                <field name="currency_id"/>
                <field name="movement_currency_id"/>
                <field name="status"/>
                <field name="difference_amount"/>
                <field name="adjustment_movement_id"/>
            </list>
        </field>
    </record>

    <record id="view_treasury_reconciliation_line_form" model="ir.ui.view">
        <field name="name">treasury.reconciliation.line.form</field>
        <field name="model">treasury.reconciliation.line</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_match_selected" string="Conciliar" type="object" invisible="status not in ('pending','divergent')"/>
                    <button name="action_create_adjustment" string="Gerar Ajuste" type="object" invisible="status not in ('pending','divergent')"/>
                    <button name="action_mark_divergent" string="Marcar Divergencia" type="object" invisible="status not in ('pending','divergent')"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="reconciliation_id" readonly="1"/>
                        <field name="statement_line_id" readonly="1"/>
                        <field name="movement_id"/>
                    </group>
                    <group>
                        <field name="currency_id" readonly="1"/>
                        <field name="movement_currency_id" readonly="1"/>
                        <field name="difference_amount" readonly="1"/>
                        <field name="adjustment_movement_id" readonly="1"/>
                    </group>
                    <group>
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_treasury_reconciliation" model="ir.actions.act_window">
        <field name="name">Conciliacoes</field>
        <field name="res_model">treasury.reconciliation</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_treasury_reconciliation"
        name="Conciliacoes"
        parent="custom_treasury_reconciliation.custom_treasury_reconciliation_menu_root"
        action="action_treasury_reconciliation"
        sequence="10"
    />
</odoo>

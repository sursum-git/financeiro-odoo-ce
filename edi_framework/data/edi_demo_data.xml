<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="edi_exchange_type_demo_api" model="edi.exchange.type">
        <field name="name">Demo API Saída</field>
        <field name="code">demo_api_out</field>
        <field name="category">api</field>
        <field name="direction">out</field>
    </record>

    <record id="edi_exchange_state_demo_draft" model="edi.exchange.state">
        <field name="exchange_type_id" ref="edi_exchange_type_demo_api"/>
        <field name="name">Rascunho</field>
        <field name="code">draft</field>
        <field name="sequence">5</field>
        <field name="state_kind">draft</field>
        <field name="is_initial" eval="True"/>
    </record>

    <record id="edi_exchange_state_demo_success" model="edi.exchange.state">
        <field name="exchange_type_id" ref="edi_exchange_type_demo_api"/>
        <field name="name">Sucesso</field>
        <field name="code">success</field>
        <field name="sequence">20</field>
        <field name="state_kind">success</field>
        <field name="is_final" eval="True"/>
    </record>

    <record id="edi_exchange_state_demo_error" model="edi.exchange.state">
        <field name="exchange_type_id" ref="edi_exchange_type_demo_api"/>
        <field name="name">Erro</field>
        <field name="code">error</field>
        <field name="sequence">30</field>
        <field name="state_kind">error</field>
        <field name="is_final" eval="True"/>
        <field name="is_error" eval="True"/>
    </record>

    <record id="edi_backend_demo" model="edi.backend">
        <field name="name">Backend Demo API</field>
        <field name="code">DEMO_API</field>
        <field name="backend_type">api</field>
        <field name="config_json">{"base_url": "https://demo.edi.local", "token": "demo-token"}</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="default_exchange_type_id" ref="edi_exchange_type_demo_api"/>
        <field name="queue_channel">root.edi.demo</field>
        <field name="description">Backend demonstrativo para processamento EDI end-to-end.</field>
    </record>

    <record id="edi_layout_demo" model="edi.layout">
        <field name="name">Layout Demo NFSe</field>
        <field name="code">DEMO_NFSE</field>
        <field name="version">1.0</field>
        <field name="backend_id" ref="edi_backend_demo"/>
        <field name="format_type">json</field>
        <field name="direction">out</field>
        <field name="encoding">utf-8</field>
        <field name="root_node">documents</field>
        <field name="notes">Layout demonstrativo com source array e target API.</field>
    </record>

    <record id="edi_data_source_demo_array" model="edi.data.source">
        <field name="name">Fonte Demo Documentos</field>
        <field name="code">DEMO_SOURCE_DOCS</field>
        <field name="source_type">array</field>
        <field name="result_mode">list</field>
        <field name="root_alias">docs</field>
        <field name="params_json">{"rows": [{"document_number": "42", "amount": "15.75", "customer_name": "ACME LTDA"}, {"document_number": "7", "amount": "3.50", "customer_name": "BETA SA"}]}</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="notes">Fonte simulada instalada como dado permanente do módulo.</field>
    </record>

    <record id="edi_layout_source_demo_docs" model="edi.layout.source">
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="source_id" ref="edi_data_source_demo_array"/>
        <field name="alias">docs</field>
        <field name="sequence">10</field>
        <field name="required" eval="True"/>
    </record>

    <record id="edi_layout_record_demo_detail" model="edi.layout.record">
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="name">Detalhe Documento</field>
        <field name="code">DET</field>
        <field name="record_type">detail</field>
        <field name="sequence">10</field>
        <field name="repeat_mode">foreach</field>
        <field name="source_alias">docs</field>
    </record>

    <record id="edi_layout_field_demo_doc_number" model="edi.layout.field">
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="sequence">10</field>
        <field name="name">Numero Documento</field>
        <field name="code">document_number</field>
        <field name="technical_name">document_number</field>
        <field name="field_type">char</field>
        <field name="target_path">doc_number</field>
    </record>

    <record id="edi_layout_field_demo_amount" model="edi.layout.field">
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="sequence">20</field>
        <field name="name">Valor</field>
        <field name="code">amount</field>
        <field name="technical_name">amount</field>
        <field name="field_type">float</field>
        <field name="target_path">amount_cents</field>
    </record>

    <record id="edi_layout_field_demo_customer" model="edi.layout.field">
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="sequence">30</field>
        <field name="name">Cliente</field>
        <field name="code">customer_name</field>
        <field name="technical_name">customer_name</field>
        <field name="field_type">char</field>
        <field name="target_path">customer_name</field>
    </record>

    <record id="edi_extract_map_demo_doc" model="edi.extract.map">
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="field_id" ref="edi_layout_field_demo_doc_number"/>
        <field name="sequence">10</field>
        <field name="source_alias">docs</field>
        <field name="source_path">document_number</field>
    </record>

    <record id="edi_extract_map_demo_amount" model="edi.extract.map">
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="field_id" ref="edi_layout_field_demo_amount"/>
        <field name="sequence">20</field>
        <field name="source_alias">docs</field>
        <field name="source_path">amount</field>
    </record>

    <record id="edi_extract_map_demo_customer" model="edi.extract.map">
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="field_id" ref="edi_layout_field_demo_customer"/>
        <field name="sequence">30</field>
        <field name="source_alias">docs</field>
        <field name="source_path">customer_name</field>
    </record>

    <record id="edi_map_rule_line_demo_doc_zfill" model="edi.map.rule.line">
        <field name="extract_map_id" ref="edi_extract_map_demo_doc"/>
        <field name="sequence">10</field>
        <field name="transform_rule_id" ref="edi_transform_rule_zfill"/>
        <field name="params_json">{"width": 6}</field>
    </record>

    <record id="edi_map_rule_line_demo_amount_multiply" model="edi.map.rule.line">
        <field name="extract_map_id" ref="edi_extract_map_demo_amount"/>
        <field name="sequence">10</field>
        <field name="transform_rule_id" ref="edi_transform_rule_multiply"/>
        <field name="params_json">{"factor": "100"}</field>
    </record>

    <record id="edi_data_target_demo_api" model="edi.data.target">
        <field name="name">Destino Demo API</field>
        <field name="code">DEMO_TARGET_API</field>
        <field name="target_type">api</field>
        <field name="params_json">{"endpoint": "/v1/invoices/demo", "method": "POST"}</field>
        <field name="company_id" ref="base.main_company"/>
        <field name="notes">Destino simulando uma API externa.</field>
    </record>

    <record id="edi_return_map_demo_api" model="edi.return.map">
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="record_id" ref="edi_layout_record_demo_detail"/>
        <field name="field_id" ref="edi_layout_field_demo_doc_number"/>
        <field name="sequence">10</field>
        <field name="target_id" ref="edi_data_target_demo_api"/>
        <field name="target_alias">api_main</field>
        <field name="target_path">doc_number</field>
        <field name="apply_mode">call_provider</field>
    </record>

    <record id="edi_transaction_demo" model="edi.transaction">
        <field name="name">Transacao Demo EDI</field>
        <field name="transaction_type">demo_api_out</field>
        <field name="backend_id" ref="edi_backend_demo"/>
        <field name="exchange_type_id" ref="edi_exchange_type_demo_api"/>
        <field name="res_model">res.partner</field>
        <field name="res_id" ref="base.partner_admin"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="current_status_message">Aguardando execucao da demo.</field>
    </record>

    <record id="edi_exchange_demo" model="edi.exchange">
        <field name="name">Exchange Demo EDI</field>
        <field name="backend_id" ref="edi_backend_demo"/>
        <field name="layout_id" ref="edi_layout_demo"/>
        <field name="exchange_type_id" ref="edi_exchange_type_demo_api"/>
        <field name="direction">out</field>
        <field name="transaction_id" ref="edi_transaction_demo"/>
        <field name="current_state_id" ref="edi_exchange_state_demo_draft"/>
        <field name="state_code">draft</field>
        <field name="state_kind">draft</field>
        <field name="external_ref">DEMO-EXCHANGE-001</field>
        <field name="res_model">res.partner</field>
        <field name="res_id" ref="base.partner_admin"/>
        <field name="company_id" ref="base.main_company"/>
        <field name="summary_message">Cenario demo pronto para execucao.</field>
    </record>

    <record id="action_edi_demo_exchange_form" model="ir.actions.act_window">
        <field name="name">Cenário Demo</field>
        <field name="res_model">edi.exchange</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="edi_exchange_demo"/>
    </record>

    <record id="action_edi_demo_backend_form" model="ir.actions.act_window">
        <field name="name">Backend Demo</field>
        <field name="res_model">edi.backend</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="edi_backend_demo"/>
    </record>

    <record id="action_edi_demo_layout_form" model="ir.actions.act_window">
        <field name="name">Layout Demo</field>
        <field name="res_model">edi.layout</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="edi_layout_demo"/>
    </record>

    <record id="action_edi_demo_transaction_form" model="ir.actions.act_window">
        <field name="name">Transação Demo</field>
        <field name="res_model">edi.transaction</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="edi_transaction_demo"/>
    </record>

    <menuitem id="edi_framework_menu_demo" name="Demonstração" parent="edi_framework_menu_root" sequence="15"/>
    <menuitem id="menu_edi_demo_exchange" name="Cenário Demo" parent="edi_framework_menu_demo" action="action_edi_demo_exchange_form" sequence="10"/>
    <menuitem id="menu_edi_demo_backend" name="Backend Demo" parent="edi_framework_menu_demo" action="action_edi_demo_backend_form" sequence="20"/>
    <menuitem id="menu_edi_demo_layout" name="Layout Demo" parent="edi_framework_menu_demo" action="action_edi_demo_layout_form" sequence="30"/>
    <menuitem id="menu_edi_demo_transaction" name="Transação Demo" parent="edi_framework_menu_demo" action="action_edi_demo_transaction_form" sequence="40"/>
</odoo>

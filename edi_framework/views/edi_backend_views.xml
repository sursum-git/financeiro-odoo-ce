<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edi_backend_tree" model="ir.ui.view">
        <field name="name">edi.backend.tree</field>
        <field name="model">edi.backend</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="queue_channel"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_edi_backend_form" model="ir.ui.view">
        <field name="name">edi.backend.form</field>
        <field name="model">edi.backend</field>
        <field name="arch" type="xml">
            <form string="Backend EDI">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="backend_type"/>
                        <field name="config_json"/>
                        <field name="company_id"/>
                        <field name="partner_id"/>
                        <field name="default_layout_id"/>
                        <field name="default_exchange_type_id"/>
                        <field name="queue_channel"/>
                        <field name="auto_use_queue"/>
                        <field name="active"/>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_edi_backend" model="ir.actions.act_window">
        <field name="name">Backends</field>
        <field name="res_model">edi.backend</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_edi_process_tree" model="ir.ui.view">
        <field name="name">edi.process.tree</field>
        <field name="model">edi.process</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="model_name"/>
                <field name="backend_id"/>
                <field name="exchange_type_id"/>
                <field name="layout_id"/>
                <field name="auto_enqueue"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_edi_process_form" model="ir.ui.view">
        <field name="name">edi.process.form</field>
        <field name="model">edi.process</field>
        <field name="arch" type="xml">
            <form string="Processo EDI">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="company_id"/>
                        <field name="model_name"/>
                        <field name="backend_id"/>
                        <field name="exchange_type_id"/>
                        <field name="layout_id"/>
                        <field name="direction"/>
                        <field name="auto_enqueue"/>
                        <field name="active"/>
                        <field name="description"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_edi_process" model="ir.actions.act_window">
        <field name="name">Processos EDI</field>
        <field name="res_model">edi.process</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_edi_backend" name="Backends" parent="edi_framework_menu_config" action="action_edi_backend" sequence="10"/>
    <menuitem id="menu_edi_process" name="Processos EDI" parent="edi_framework_menu_config" action="action_edi_process" sequence="15"/>
</odoo>

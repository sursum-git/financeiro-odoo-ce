<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edi_demo_reset_wizard_form" model="ir.ui.view">
        <field name="name">edi.demo.reset.wizard.form</field>
        <field name="model">edi.demo.reset.wizard</field>
        <field name="arch" type="xml">
            <form string="Resetar Demo EDI">
                <group>
                    <field name="exchange_id"/>
                    <field name="reset_logs"/>
                    <field name="run_after_reset"/>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Confirmar" class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>

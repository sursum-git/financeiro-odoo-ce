<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edi_layout_tree" model="ir.ui.view">
        <field name="name">edi.layout.tree</field>
        <field name="model">edi.layout</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="code"/>
                <field name="backend_id"/>
                <field name="format_type"/>
                <field name="direction"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_edi_layout_form" model="ir.ui.view">
        <field name="name">edi.layout.form</field>
        <field name="model">edi.layout</field>
        <field name="arch" type="xml">
            <form string="Layout EDI">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="code"/>
                        <field name="version"/>
                        <field name="backend_id"/>
                        <field name="company_id"/>
                        <field name="format_type"/>
                        <field name="direction"/>
                        <field name="record_length"/>
                        <field name="delimiter"/>
                        <field name="encoding"/>
                        <field name="line_ending"/>
                        <field name="root_node"/>
                        <field name="notes"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Registros">
                            <field name="record_ids"/>
                        </page>
                        <page string="Fontes">
                            <field name="source_ids"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_edi_layout" model="ir.actions.act_window">
        <field name="name">Layouts</field>
        <field name="res_model">edi.layout</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_edi_layout_record_tree" model="ir.ui.view">
        <field name="name">edi.layout.record.tree</field>
        <field name="model">edi.layout.record</field>
        <field name="arch" type="xml">
            <list>
                <field name="layout_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="record_type"/>
                <field name="sequence"/>
            </list>
        </field>
    </record>
    <record id="action_edi_layout_record" model="ir.actions.act_window">
        <field name="name">Registros de Layout</field>
        <field name="res_model">edi.layout.record</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_edi_layout_field_tree" model="ir.ui.view">
        <field name="name">edi.layout.field.tree</field>
        <field name="model">edi.layout.field</field>
        <field name="arch" type="xml">
            <list>
                <field name="record_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="field_type"/>
                <field name="sequence"/>
            </list>
        </field>
    </record>
    <record id="action_edi_layout_field" model="ir.actions.act_window">
        <field name="name">Campos de Layout</field>
        <field name="res_model">edi.layout.field</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_edi_layout" name="Layouts" parent="edi_framework_menu_config" action="action_edi_layout" sequence="20"/>
    <menuitem id="menu_edi_layout_record" name="Registros de Layout" parent="edi_framework_menu_config" action="action_edi_layout_record" sequence="30"/>
    <menuitem id="menu_edi_layout_field" name="Campos de Layout" parent="edi_framework_menu_config" action="action_edi_layout_field" sequence="40"/>
</odoo>

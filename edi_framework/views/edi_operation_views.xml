<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_edi_exchange_tree" model="ir.ui.view">
        <field name="name">edi.exchange.tree</field>
        <field name="model">edi.exchange</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="backend_id"/>
                <field name="exchange_type_id"/>
                <field name="state_code"/>
                <field name="has_error"/>
                <field name="started_at"/>
                <field name="finished_at"/>
            </list>
        </field>
    </record>
    <record id="view_edi_exchange_form" model="ir.ui.view">
        <field name="name">edi.exchange.form</field>
        <field name="model">edi.exchange</field>
        <field name="arch" type="xml">
            <form string="Exchange EDI">
                <header>
                    <button name="action_enqueue_process" type="object" string="Processar" class="btn-primary"/>
                    <button name="action_run_demo_now" type="object" string="Executar Demo Agora" class="btn-secondary"/>
                    <button name="action_open_demo_reset_wizard" type="object" string="Resetar Demo" class="btn-secondary"/>
                </header>
                <sheet>
                    <group>
                        <field name="has_error" invisible="1"/>
                        <field name="state_kind" invisible="1"/>
                        <field
                            name="last_result_label"
                            widget="badge"
                            decoration-success="state_kind == 'success' and not has_error"
                            decoration-danger="has_error"
                            decoration-warning="state_kind == 'draft'"
                            decoration-info="state_kind == 'processing'"
                        />
                    </group>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_run_demo_now" class="oe_stat_button" icon="fa-play">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Último Resultado</span>
                                <span class="o_stat_value">
                                    <field name="last_result_label" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_demo_reset_wizard" class="oe_stat_button" icon="fa-refresh">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Payloads</span>
                                <span class="o_stat_value">
                                    <field name="payload_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_demo_reset_wizard" class="oe_stat_button" icon="fa-database">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Snapshots</span>
                                <span class="o_stat_value">
                                    <field name="snapshot_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_demo_reset_wizard" class="oe_stat_button" icon="fa-cloud">
                            <div class="o_stat_info">
                                <span class="o_stat_text">APIs</span>
                                <span class="o_stat_value">
                                    <field name="api_detail_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_demo_reset_wizard" class="oe_stat_button" icon="fa-file-text-o">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Arquivos</span>
                                <span class="o_stat_value">
                                    <field name="file_detail_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_demo_reset_wizard" class="oe_stat_button" icon="fa-list-alt">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Logs</span>
                                <span class="o_stat_value">
                                    <field name="log_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_demo_reset_wizard" class="oe_stat_button" icon="fa-history">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Eventos</span>
                                <span class="o_stat_value">
                                    <field name="event_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <field name="name"/>
                        <field name="backend_id"/>
                        <field name="layout_id"/>
                        <field name="exchange_type_id"/>
                        <field name="transaction_id"/>
                        <field name="current_state_id"/>
                        <field name="state_code"/>
                        <field name="state_kind"/>
                        <field name="external_ref"/>
                        <field name="has_error"/>
                        <field name="summary_message"/>
                        <field name="error_message"/>
                    </group>
                    <notebook>
                        <page string="Payloads">
                            <field name="payload_ids">
                                <list>
                                    <field name="payload_type"/>
                                    <field name="name"/>
                                    <field name="created_at"/>
                                </list>
                            </field>
                        </page>
                        <page string="Snapshots">
                            <field name="source_snapshot_ids">
                                <list>
                                    <field name="source_id"/>
                                    <field name="captured_at"/>
                                    <field name="payload_hash"/>
                                </list>
                            </field>
                        </page>
                        <page string="API">
                            <field name="api_detail_id">
                                <list>
                                    <field name="url"/>
                                    <field name="http_method"/>
                                    <field name="remote_status"/>
                                </list>
                            </field>
                        </page>
                        <page string="Arquivos">
                            <field name="file_detail_id">
                                <list>
                                    <field name="file_name"/>
                                    <field name="file_format"/>
                                    <field name="record_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_edi_exchange" model="ir.actions.act_window">
        <field name="name">Exchanges</field>
        <field name="res_model">edi.exchange</field>
        <field name="view_mode">list,form</field>
    </record>
    <record id="view_edi_transaction_tree" model="ir.ui.view">
        <field name="name">edi.transaction.tree</field>
        <field name="model">edi.transaction</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="transaction_type"/>
                <field name="backend_id"/>
                <field name="business_state"/>
                <field name="technical_state"/>
                <field name="has_error"/>
                <field name="last_event_at"/>
            </list>
        </field>
    </record>
    <record id="view_edi_transaction_form" model="ir.ui.view">
        <field name="name">edi.transaction.form</field>
        <field name="model">edi.transaction</field>
        <field name="arch" type="xml">
            <form string="Transação EDI">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button type="object" name="action_open_exchanges" class="oe_stat_button" icon="fa-random">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Exchanges</span>
                                <span class="o_stat_value">
                                    <field name="exchange_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_events" class="oe_stat_button" icon="fa-history">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Eventos</span>
                                <span class="o_stat_value">
                                    <field name="event_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object" name="action_open_logs" class="oe_stat_button" icon="fa-list-alt">
                            <div class="o_stat_info">
                                <span class="o_stat_text">Logs</span>
                                <span class="o_stat_value">
                                    <field name="log_count" nolabel="1"/>
                                </span>
                            </div>
                        </button>
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="transaction_type"/>
                            <field name="exchange_type_id"/>
                            <field name="backend_id"/>
                            <field name="current_exchange_id"/>
                            <field name="external_ref"/>
                        </group>
                        <group>
                            <field name="res_model"/>
                            <field name="res_id"/>
                            <field name="technical_state"/>
                            <field name="business_state"/>
                            <field name="has_error"/>
                            <field name="waiting_return"/>
                        </group>
                    </group>
                    <group>
                        <group>
                            <field name="started_at"/>
                            <field name="last_event_at"/>
                            <field name="finished_at"/>
                        </group>
                        <group>
                            <field name="current_status_message"/>
                            <field name="error_message" invisible="not has_error"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Exchanges">
                            <field name="exchange_ids" context="{'default_transaction_id': id}">
                                <list>
                                    <field name="name"/>
                                    <field name="exchange_type_id"/>
                                    <field name="state_code"/>
                                    <field name="state_kind"/>
                                    <field name="has_error"/>
                                    <field name="started_at"/>
                                    <field name="finished_at"/>
                                </list>
                            </field>
                        </page>
                        <page string="Eventos">
                            <field name="event_ids" context="{'default_transaction_id': id}">
                                <list>
                                    <field name="event_datetime"/>
                                    <field name="event_type"/>
                                    <field name="event_code"/>
                                    <field name="exchange_id"/>
                                    <field name="technical_state_to"/>
                                    <field name="business_state_to"/>
                                    <field name="is_error"/>
                                    <field name="message"/>
                                </list>
                            </field>
                        </page>
                        <page string="Logs">
                            <field name="log_ids" context="{'default_transaction_id': id}">
                                <list>
                                    <field name="log_datetime"/>
                                    <field name="log_type"/>
                                    <field name="key"/>
                                    <field name="exchange_id"/>
                                    <field name="message"/>
                                    <field name="value"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="action_edi_transaction" model="ir.actions.act_window">
        <field name="name">Transações</field>
        <field name="res_model">edi.transaction</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem id="menu_edi_exchange" name="Exchanges" parent="edi_framework_menu_operations" action="action_edi_exchange" sequence="10"/>
    <menuitem id="menu_edi_transaction" name="Transações" parent="edi_framework_menu_operations" action="action_edi_transaction" sequence="20"/>
</odoo>
